# Copy this file to .env and fill in the values
# Never commit .env to git

# Application
APP_NAME=gabrielle
DEBUG=false

# LLM provider — all required, no defaults
# provider: openai | anthropic
LLM_PROVIDER=
# model: e.g. gpt-4o, claude-3-5-sonnet-20241022
LLM_MODEL=
LLM_API_KEY=

# Tavily web search
TAVILY_API_KEY=
